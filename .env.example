AQUA_API_KEY=
AQUA_BASE_URL=https://api.aquadevs.com/v1
AQUA_CHAT_MODEL=grok-4.3
AQUA_IMAGE_MODEL=gptimage-2

# Optional small/fast model for HOUSEKEEPING ONLY: compacting old transcript
# into a running summary, trimming memory, and flagging duplicate/stale NPCs so
# the large RP model never suffers context collapse. It never directs live
# narration, ambience, effects, or backdrops — those always run on
# AQUA_CHAT_MODEL. Empty = housekeeping is skipped (the char budget below is
# the only safety net).
FAST_MODEL=

# Optional: host the small model on a DIFFERENT OpenAI-compatible provider.
# Leave BOTH empty to reuse AQUA_BASE_URL / AQUA_API_KEY (same provider as the
# large model). Each falls back independently, so you can override just the URL.
FAST_BASE_URL=
FAST_API_KEY=

# Server-log verbosity (off by default so the console isn't flooded). Errors
# always print regardless.
#   1 = tool calls, DM steps, and game logic
#   2 = everything, including the noisy per-request "API …" logs
DEBUG_VERBOSE=

# Turn/round idle deadline in ms (default 90000). Past it, the host nudges the
# server to resolve an exploration round or skip an idle combatant.
TURN_TIMEOUT_MS=90000
# A player is considered "away" this long after their last controller poll (ms).
PLAYER_AWAY_MS=20000
# Max DM tool-calling steps per turn (default 16). Raise for very heavy combat.
AQUA_MAX_TOOL_STEPS=16
# Interactive DM-turn network retries + per-attempt timeout (fail fast so a dead
# endpoint surfaces in seconds, not minutes).
AQUA_INTERACTIVE_RETRIES=3
AQUA_INTERACTIVE_TIMEOUT_MS=45000
# Max characters (NOT tokens) of recent transcript fed to the DM each turn. The
# chat model supports up to ~1M tokens of context, but quality degrades well
# before that ceiling, so keep this well under the model's true limit.
AQUA_MAX_CONTEXT_CHARS=250000
