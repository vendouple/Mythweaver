API_KEY=
BASE_URL=https://api.aquadevs.com/v1
CHAT_MODEL=hy3
IMAGE_MODEL=nanobanana-pro
# Optional: image model on a DIFFERENT OpenAI-compatible provider. Leave BOTH
# empty to reuse BASE_URL / API_KEY (same provider as the chat model). Each
# falls back independently, so you can override just the URL.
IMAGE_BASE_URL=
IMAGE_API_KEY=

# Optional small/fast model for HOUSEKEEPING ONLY: compacting old transcript
# into a running summary, trimming memory, and flagging duplicate/stale NPCs so
# the large RP model never suffers context collapse. It never directs live
# narration, ambience, effects, or backdrops — those always run on
# CHAT_MODEL. Empty = housekeeping is skipped (the char budget below is
# the only safety net).
FAST_MODEL=

# Optional: host the small model on a DIFFERENT OpenAI-compatible provider.
# Leave BOTH empty to reuse BASE_URL / API_KEY (same provider as the
# large model). Each falls back independently, so you can override just the URL.
FAST_BASE_URL=
FAST_API_KEY=

# Server-log verbosity (off by default so the console isn't flooded). Errors
# always print regardless.
#   1 = tool calls, DM steps, and game logic
#   2 = everything, including the noisy per-request "API …" logs
DEBUG_VERBOSE=

# Turn/round idle deadline in ms (default 90000). Past it, the host nudges the
# server to resolve an exploration round or skip an idle combatant.
TURN_TIMEOUT_MS=90000
# A player is considered "away" this long after their last controller poll (ms).
PLAYER_AWAY_MS=20000
# How long (ms) a TV/Host screen's heartbeat stays "live" after its last poll.
# Governs both the controllers' "waiting for the screen" banner and how long a
# closed TV must be gone before a freshly opened one claims the session with no
# takeover prompt (default 15000).
HOST_SESSION_STALE_MS=15000
# How long (ms) a player must stay disconnected before the DM writes their
# departure into the story (parks them safely, never kills them). Kept well
# above PLAYER_AWAY_MS so a slow-loading phone at session resume never triggers
# an in-fiction exit for what's really just a brief reconnect (default 2 min).
DEPARTURE_WEAVE_GRACE_MS=120000
# Max DM tool-calling steps per turn (default 16). Raise for very heavy combat.
MAX_TOOL_STEPS=16
# Interactive DM-turn network retries + per-attempt timeout (fail fast so a dead
# endpoint surfaces in seconds, not minutes).
INTERACTIVE_RETRIES=3
INTERACTIVE_TIMEOUT_MS=45000
# Wait this long between retries on 5xx/429/network errors (ms). Unstable APIs
# that just need hammering should use a short fixed delay (e.g. 1000).
RETRY_DELAY_MS=1000
# 0 = fixed delay every retry (default). 1 = linear backoff (attempt * delay).
RETRY_BACKOFF=0
# If a turn's final response can't be parsed into JSON, retry this many times
# by forcing the narrate_turn tool call before giving up and rolling the turn
# back (default 3).
PARSE_RETRIES=3
# Those forced-narrate_turn retries are pure reformatting of a turn the large
# model already decided (no new creative content), so when FAST_MODEL is
# configured they route there by default — cheaper/faster than re-running the
# whole conversation through the large model. Set to 0 to always retry with
# CHAT_MODEL instead, e.g. if the small model starts altering the narration
# instead of just repackaging it.
PARSE_RETRY_USE_FAST_MODEL=1
# Max characters (NOT tokens) of recent transcript fed to the DM each turn. The
# chat model supports up to ~1M tokens of context, but quality degrades well
# before that ceiling, so keep this well under the model's true limit.
MAX_CONTEXT_CHARS=250000
